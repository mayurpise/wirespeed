{
  "name": "how-fast",
  "version": "1.0.0",
  "description": "Terminal internet speed test — download, upload, and latency",
  "type": "module",
  "bin": {
    "how-fast": "./bin/how-fast.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/src/index.js",
    "prepublishOnly": "npm run build"
