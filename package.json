    "terminal",
    "cloudflare",
    "wirespeed"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-spinners": "^3.2.0",
    "is-unicode-supported": "^2.1.0",
    "log-update": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
